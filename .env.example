# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Works with Neon, Render PostgreSQL, or any PG.
# Example (Neon):  postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require
# Example (Render): postgresql://user:pass@dpg-xxx.render.com/dbname
DATABASE_URL=

# ── Session ───────────────────────────────────────────────────────────────────
# A long random string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ── Discord OAuth2 ────────────────────────────────────────────────────────────
# From https://discord.com/developers/applications → Your App → OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── Discord Bot ───────────────────────────────────────────────────────────────
# From https://discord.com/developers/applications → Your App → Bot → Token
DISCORD_BOT_TOKEN=

# ── Discord Server ────────────────────────────────────────────────────────────
# Right-click your Discord server → Copy Server ID (requires Developer Mode)
DISCORD_GUILD_ID=

# ── DeepSeek AI ───────────────────────────────────────────────────────────────
# From https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=
